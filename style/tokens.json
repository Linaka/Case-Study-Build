{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "meta": {
    "name": "Monochrome editorial case-study system",
    "source": "style/brand.md",
    "updated": "2026-05-17"
  },
  "colors": {
    "ink": "#000000",
    "canvas": "#ffffff",
    "canvasSoft": "#efefef",
    "canvasSofter": "#f6f6f6",
    "hairline": "#d8d8d8",
    "hairlineMid": "#4b4b4b",
    "body": "#5e5e5e",
    "mute": "#afafaf",
    "onDark": "#ffffff"
  },
  "typography": {
    "fontFamilyDisplay": "Inter, Arial, Helvetica, sans-serif",
    "fontFamilyText": "Inter, Arial, Helvetica, sans-serif",
    "displayXxl": {
      "fontSize": "58px",
      "fontWeight": 700,
      "lineHeight": "64px",
      "letterSpacing": "0"
    },
    "displayXl": {
      "fontSize": "42px",
      "fontWeight": 700,
      "lineHeight": "48px",
      "letterSpacing": "0"
    },
    "displayLg": {
      "fontSize": "32px",
      "fontWeight": 700,
      "lineHeight": "38px",
      "letterSpacing": "0"
    },
    "displayMd": {
      "fontSize": "24px",
      "fontWeight": 700,
      "lineHeight": "31px",
      "letterSpacing": "0"
    },
    "bodyLg": {
      "fontSize": "18px",
      "fontWeight": 500,
      "lineHeight": "28px",
      "letterSpacing": "0"
    },
    "bodyMd": {
      "fontSize": "16px",
      "fontWeight": 400,
      "lineHeight": "25px",
      "letterSpacing": "0"
    },
    "bodyMdStrong": {
      "fontSize": "16px",
      "fontWeight": 500,
      "lineHeight": "22px",
      "letterSpacing": "0"
    },
    "bodySm": {
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": "20px",
      "letterSpacing": "0"
    },
    "caption": {
      "fontSize": "12px",
      "fontWeight": 400,
      "lineHeight": "18px",
      "letterSpacing": "0"
    }
  },
  "spacing": {
    "xxs": "4px",
    "xs": "6px",
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "20px",
    "2xl": "24px",
    "3xl": "32px",
    "4xl": "48px",
    "5xl": "64px"
  },
  "radii": {
    "none": "0",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "pill": "999px"
  },
  "shadows": {
    "none": "none",
    "subtle": "0 4px 16px rgba(0, 0, 0, 0.12)"
  },
  "layout": {
    "container": "1200px",
    "pdfPage": "A4",
    "pdfMargin": "18mm",
    "imageRatios": ["4 / 3", "16 / 9"]
  }
}
